# ============================================================
# .gitignore
# Smart Scheduling and Demand Response for Water Utilities
# ============================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Environment variables (API keys)
.env
*.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/

# Editor and OS artifacts
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Pyomo solver scratch files
*.lp
*.mps
*.sol
*.glpk.log

# Jupyter notebooks (not part of this project)
.ipynb_checkpoints/
*.ipynb

# Note: logs/ is intentionally NOT ignored.
# The CSV simulation output files in logs/ are the primary
# dataset referenced in the final report and are included
# in the repository for reproducibility.
